# Copy to .env.local (Next.js reads .env.local automatically).
# Must match where uvicorn listens (default port 8000).

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# How often the live feed merges /history over REST (ms). Default 3000.
# NEXT_PUBLIC_FEED_POLL_MS=3000
