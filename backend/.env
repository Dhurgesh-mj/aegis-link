# Aegis-Link — Engine Configuration
# Fill in your API keys below.
# NO TWITTER — replaced with 4chan /biz/, StockTwits, CryptoPanic.

# ── Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=YOUR_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_SECRET
REDDIT_USER_AGENT=aegis-link/1.0 by u/aegis-bot

# ── Telegram API (https://my.telegram.org/apps)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=YOUR_API_HASH_HERE

# ── CryptoPanic (https://cryptopanic.com/developers/api/)
# Free token — sign up and get it instantly
CRYPTOPANIC_TOKEN=your_cryptopanic_token

# ── Global Broadcast (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Core Infrastructure
JWT_SECRET=generate-a-long-random-string-here
OLLAMA_HOST=http://localhost:11434
REDIS_HOST=localhost
REDIS_PORT=6379
