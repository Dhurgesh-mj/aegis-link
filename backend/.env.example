# =============================================================================
# Aegis-Link — backend environment (copy to .env and fill in)
# =============================================================================
#
# REQUIRED for a working site
# ---------------------------
# - Redis (JWT auth, users, WebSocket fan-out). Defaults below assume local Redis.
# - JWT_SECRET: use a long random string in any real deployment.
#
# OPTIONAL — data sources (collectors disable themselves if unset)
# ---------------------------------------------------------------
# - Reddit, Telegram user API, CryptoPanic: need keys below.
# - CoinGecko, 4chan /biz/, StockTwits: no keys in .env (public HTTP).
#
# OPTIONAL — intelligence / alerts
# --------------------------------
# - Ollama: sentiment uses local LLM; if Ollama is down, analysis falls back.
# - Discord webhook / Telegram bot: global broadcast from notification_router.
#
# =============================================================================

# --- Redis (required) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth (required for register/login) ---
JWT_SECRET=change-this-to-a-long-random-string-in-production

# --- Reddit (optional) — 401 = bad OAuth credentials or user_agent ----------
# 1) Open https://www.reddit.com/prefs/apps → "create another app" (or "create app")
# 2) Type: "script" | Name: anything | Redirect: http://localhost:8080 (unused for script)
# 3) REDDIT_CLIENT_ID = the short string UNDER the app name (not the name itself)
# 4) REDDIT_CLIENT_SECRET = the field labeled "secret" — NOT your Reddit password
# 5) USER_AGENT must be unique and identify you (Reddit API rules):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AegisLink/1.0 (by /u/YourRedditUsername)

# --- Telegram user API for Telethon collector (optional) https://my.telegram.org ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- CryptoPanic news (optional) https://cryptopanic.com/developers/api/ ---
CRYPTOPANIC_TOKEN=

# --- Engine cadence (optional — defaults are conservative) ---
# CoinGecko + Reddit collectors sleep POLL_INTERVAL seconds between polls.
# A coin needs MIN_COIN_EVENTS_FOR_SIGNAL mentions inside EVENT_WINDOW_SEC before a signal is emitted.
# Defaults in config.py are already fairly snappy (30s / min 2 events). Tighten more if needed:
# POLL_INTERVAL=20
POLL_INTERVAL=30
FOURCHAN_INTERVAL=120
MIN_COIN_EVENTS_FOR_SIGNAL=2
EVENT_WINDOW_SEC=600

# --- Ollama sentiment (optional) https://ollama.com ---
# If Ollama is not running, the engine uses a simple keyword heuristic instead (no ERROR spam).
# To skip calling Ollama entirely: OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_ENABLED=true

# --- Global outbound alerts (optional) ---
DISCORD_WEBHOOK_URL=
# Bot token from @BotFather — also used by telegram_chat_bot.py (users send /start to get chat ID)
TELEGRAM_BOT_TOKEN=
# Optional: single chat/channel for subscribers/telegram_sub.py (all signals)
TELEGRAM_CHAT_ID=
